{
  "name": "troxe-host",
  "version": "0.1.0",
  "private": true,
  "description": "Game server management panel - like Pterodactyl but customizable",
  "workspaces": [
    "panel",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:panel\" \"npm run dev:frontend\"",
    "dev:panel": "npm run dev --workspace=panel",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "build:panel": "npm run build --workspace=panel",
    "build:frontend": "npm run build --workspace=frontend",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "npm run db:migrate --workspace=panel",
    "db:seed": "npm run db:seed --workspace=panel"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^8.1.1",
    "fastify": "^5.10.0"
  }
}
